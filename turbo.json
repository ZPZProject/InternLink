{
	"$schema": "https://turborepo.org/schema.json",
	"globalDependencies": ["**/.env"],
	"ui": "tui",
	"tasks": {
		"topo": {
			"dependsOn": ["^topo"]
		},
		"build": {
			"env": ["SUPABASE_SERVICE_KEY", "SUPABASE_API_KEY"],
			"inputs": ["$TURBO_DEFAULT$", ".env"],
			"dependsOn": ["^build"],
			"outputs": [
				".next/**",
				"!.next/cache/**",
				"next-env.d.ts",
				".expo/**",
				"dist/**",
				"release/**"
			]
		},
		"start": {
			"cache": false
		},
		"test": {
			"cache": false
		},
		"clean": {
			"cache": false
		},
		"dev": {
			"inputs": ["$TURBO_DEFAULT$", ".env"],
			"persistent": true,
			"cache": false
		},
		"jobs": {
			"persistent": true,
			"cache": false
		},
		"lint": {
			"dependsOn": ["^topo"]
		},
		"typecheck": {
			"dependsOn": ["^topo"],
			"outputs": ["node_modules/.cache/tsbuildinfo.json"]
		}
	}
}
